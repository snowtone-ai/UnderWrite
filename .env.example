# ============================================================
# UnderWrite — Environment Template
# Copy to .env.local (never commit real values).
# ============================================================

# --- AI Provider (swappable) ---------------------------------
# Selects the active AI implementation in lib/ai.
# Supported: gemini | claude | openai (gemini is the initial default)
AI_PROVIDER=gemini

# Gemini (initial default — free tier)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Claude (future swap target)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI (future swap target)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Supabase (Postgres + Auth + Storage) --------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Public Data APIs (Japanese gov open data) ---------------
# 国交省 不動産情報ライブラリ API key (https://www.reinfolib.mlit.go.jp/)
REINFOLIB_API_KEY=

# --- App ------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
